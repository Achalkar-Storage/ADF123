{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF12309"
		},
		"LS_DES_GIT_ADLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_DES_GIT_ADLS'"
		},
		"LS_GM_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_GM'"
		},
		"LS__destination_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS__destination'"
		},
		"HttpServer1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"LS_DES_GIT_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datasource999.dfs.core.windows.net/"
		},
		"LS_GM_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datasource999.dfs.core.windows.net/"
		},
		"LS__destination_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datasource999.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF12309_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_DES_GIT_ADLS_accountKey": {
						"value": "[parameters('LS_DES_GIT_ADLS_accountKey')]"
					},
					"LS_GM_accountKey": {
						"value": "[parameters('LS_GM_accountKey')]"
					},
					"LS__destination_accountKey": {
						"value": "[parameters('LS__destination_accountKey')]"
					},
					"HttpServer1_properties_typeProperties_url": {
						"value": "[parameters('HttpServer1_properties_typeProperties_url')]"
					},
					"LS_DES_GIT_ADLS_properties_typeProperties_url": {
						"value": "[parameters('LS_DES_GIT_ADLS_properties_typeProperties_url')]"
					},
					"LS_GM_properties_typeProperties_url": {
						"value": "[parameters('LS_GM_properties_typeProperties_url')]"
					},
					"LS__destination_properties_typeProperties_url": {
						"value": "[parameters('LS__destination_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}